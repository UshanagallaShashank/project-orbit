# ── Gemini (voice + orchestration) ────────────────────────────────────────────
GEMINI_API_KEY=

# ── Supabase ───────────────────────────────────────────────────────────────────
SUPABASE_URL=                  # https://xxxx.supabase.co
SUPABASE_ANON_KEY=             # safe to expose in frontend
SUPABASE_SERVICE_KEY=          # backend only — never put this in the frontend

# ── Integrations ───────────────────────────────────────────────────────────────
GITHUB_TOKEN=
GOOGLE_CALENDAR_CREDS=         # path to credentials.json from GCP Console
LINKEDIN_MCP_TOKEN=

# ── CORS (comma-separated origins, * for local dev) ───────────────────────────
ALLOWED_ORIGINS=http://localhost:5173

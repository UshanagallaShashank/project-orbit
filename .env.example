# Copy this file to server/.env and fill in real values
# Never commit server/.env to git

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here   # from Supabase dashboard > Settings > API
GOOGLE_API_KEY=your-gemini-api-key-here
JWT_SECRET=make-this-a-long-random-string-at-least-32-chars
PORT=8000
